{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moments",
  "version": "../package.json",
  "identifier": "com.sondreb.moments",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/moments/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Moments",
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "resources": ["../samples"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
